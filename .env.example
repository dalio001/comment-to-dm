# ─── Webhook security (required) ───────────────────────────────────────────
# A random string YOU invent; you'll paste the same value into the Meta webhook
# config so the GET verification handshake matches.
WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string

# Your Facebook App Secret (App Dashboard → Settings → Basic). Used to validate
# the X-Hub-Signature-256 header on every incoming webhook. If left blank the app
# will SKIP signature validation (dev only — never deploy without this).
FACEBOOK_APP_SECRET=

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./app.db

# ─── Optional first-boot seeding ────────────────────────────────────────────
# Credentials normally live in the dashboard Settings page (stored in the DB).
# These are only read ONCE, to seed an empty Config on first startup. After that,
# manage them in the dashboard. Leave blank if you'll use the UI.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ─── Runtime ────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
